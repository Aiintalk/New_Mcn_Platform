DATABASE_URL=postgresql+asyncpg://postgres:admin123@localhost:5432/mcn_m1
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=Admin@123456
ENCRYPTION_KEY=change-me-32-chars-encryption-key

# ─── AI 服务（默认值，可被 DB service_credentials 覆盖）───
LLM_API_BASE=https://yunwu.ai/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=claude-haiku-4-5-20251001

# ─── TikHub 服务（可被 DB service_credentials 覆盖）──────
TIKHUB_API_KEY=your_tikhub_api_key_here
TIKHUB_BASE_URL=https://api.tikhub.io

